{
  "name": "algopay",
  "version": "0.1.0",
  "description": "Agentic payment wallet for Algorand",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "dev:cli": "npm run dev -w @algopay/cli",
    "dev:backend": "npm run dev -w @algopay/backend"
  },
  "keywords": [
    "algorand",
    "wallet",
    "agentic",
    "ai",
    "payments"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
