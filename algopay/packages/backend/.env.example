# Database Configuration
DATABASE_URL=postgresql+asyncpg://algopay:algopay@localhost:5432/algopay

# JWT Configuration
JWT_SECRET_KEY=change-this-to-a-secure-random-key-in-production

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3

# Email Configuration (SMTP)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@algopay.io
SMTP_FROM_NAME=Algopay

# Intermezzo Configuration
INTERMEZZO_URL=http://localhost:3000
INTERMEZZO_VAULT_TOKEN=your-vault-token-here
INTERMEZZO_VAULT_ROLE_ID=
INTERMEZZO_VAULT_SECRET_ID=

# Network Configuration
DEFAULT_NETWORK=testnet
