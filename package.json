{
  "name": "x402-wallet-mcp",
  "version": "0.1.0",
  "description": "Minimal MCP server — x402 wallet with check_balance, pay, and x402_fetch tools",
  "type": "module",
  "bin": {
    "x402-wallet-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts' '__tests__/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' '__tests__/**/*.ts'",
    "format:fix": "prettier --write 'src/**/*.ts' '__tests__/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:mcpb": "bash scripts/build-mcpb.sh",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@x402-avm/avm": "^2.6.1",
    "@x402-avm/core": "^2.6.1",
    "@x402-avm/fetch": "^2.6.1",
    "@x402/core": "^2.8.0",
    "@x402/evm": "^2.8.0",
    "@x402/stellar": "^2.8.0",
    "algosdk": "^3.5.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.21",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.2.1"
  },
  "keywords": [
    "x402",
    "wallet",
    "mcp",
    "usdc",
    "payments",
    "stellar",
    "base",
    "agent-commerce"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/402md/x402-wallet-for-claude-desktop"
  },
  "engines": {
    "node": ">=18"
  }
}
